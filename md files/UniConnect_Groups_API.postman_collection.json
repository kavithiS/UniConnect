            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Web Development Team\",\n  \"description\": \"Building modern web applications with React and Node.js\",\n  \"requiredSkills\": [\"React\", \"Node.js\", \"MongoDB\"],\n  \"memberLimit\": 5\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/groups",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "groups"]
            }
          }
